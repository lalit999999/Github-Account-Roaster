# Frontend Configuration
# URL of the backend API server
VITE_API_URL=http://localhost:5000

# Backend Configuration
# GitHub Personal Access Token (generated from https://github.com/settings/tokens)
# Scopes needed: public_repo, read:user
GITHUB_TOKEN=your_github_token_here

# AI API Key (Google Gemini API from Google AI Studio)
# Get from https://aistudio.google.com/app/apikey
AI_API_KEY=your_google_ai_studio_key_here

# Server Port
PORT=5000

# Environment
NODE_ENV=development

# Frontend URL (for CORS - used when running in production)
FRONTEND_URL=http://localhost:5173
